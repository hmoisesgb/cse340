<header id="top-header">
    <span class="siteName">
        <a href="/" title="Return to home page">CSE Motors</a>
    </span>
    <div id="tools">
        <% if (locals.loggedin==1){ %>
            <a href="/account/" title="Click to manage account">Welcome, <%= locals.accountData.account_firstname %>!</a>
             |
            <a href="/favorites/" title="Click to view favorites">Favorites</a>
             |
            <a href="/account/logout" title="Click to logout">Logout</a>
        <% } else { %>
            <a href="/account/login" title="Click to log in">My Account</a>
        <% } %>
    </div>
</header>